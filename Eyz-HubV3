local function CreateESP(player)
    if player == LocalPlayer or ESPObjects[player] then return end
    
    local espData = { Billboard = nil, DistanceLabel = nil, Highlight = nil }
    
    local function SetupElements(char)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        local humanoid = char:WaitForChild("Humanoid", 5)
        if not hrp or not humanoid then return end
        
        local Billboard = Instance.new("BillboardGui")
        Billboard.Size = UDim2.new(0, 150, 0, 50)
        Billboard.StudsOffset = Vector3.new(0, 3, 0)
        Billboard.AlwaysOnTop = true
        Billboard.Parent = hrp
        
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Text = player.Name
        NameLabel.TextColor3 = Theme.Text
        NameLabel.Font = Enum.Font.Gotham
        NameLabel.TextSize = 13
        NameLabel.TextStrokeColor3 = Theme.Background
        NameLabel.TextStrokeTransparency = 0.3
        NameLabel.Parent = Billboard
        
        local DistanceLabel = Instance.new("TextLabel")
        DistanceLabel.Size = UDim2.new(1, 0, 0.5, 0)
        DistanceLabel.Position = UDim2.new(0, 0, 0.5, 0)
        DistanceLabel.BackgroundTransparency = 1
        DistanceLabel.Text = "..."
        DistanceLabel.TextColor3 = Theme.AccentSecondary
        DistanceLabel.Font = Enum.Font.Gotham
        DistanceLabel.TextSize = 11
        DistanceLabel.TextStrokeColor3 = Theme.Background
        DistanceLabel.TextStrokeTransparency = 0.3
        DistanceLabel.Parent = Billboard
        
        local Highlight = Instance.new("Highlight")
        Highlight.FillColor = Theme.Accent
        Highlight.FillTransparency = 0.7
        Highlight.OutlineColor = Theme.AccentGlow
        Highlight.OutlineTransparency = 0
        Highlight.Parent = char
        
        espData.Billboard = Billboard
        espData.DistanceLabel = DistanceLabel
        espData.Highlight = Highlight
    end
    
    if player.Character then SetupElements(player.Character) end
    espData.CharConnect = player.CharacterAdded:Connect(SetupElements)
    ESPObjects[player] = espData
end

local function RemoveESP(player)
    local data = ESPObjects[player]
    if data then
        if data.Billboard then data.Billboard:Destroy() end
        if data.Highlight then data.Highlight:Destroy() end
        if data.CharConnect then data.CharConnect:Disconnect() end
        ESPObjects[player] = nil
    end
end

RunService.RenderStepped:Connect(function()
    if not ESPEnabled then return end
    local localHrp = GetHumanoidRootPart()
    if not localHrp then return end
    
    for player, data in pairs(ESPObjects) do
        if player.Character and data.DistanceLabel then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local hum = player.Character:FindFirstChild("Humanoid")
            if hrp and hum then
                local dist = (hrp.Position - localHrp.Position).Magnitude
                data.DistanceLabel.Text = string.format("%.0fm • %d/%d HP", dist, math.floor(hum.Health), math.floor(hum.MaxHealth))
            end
        end
    end
end)

local function ToggleESP(enabled)
    ESPEnabled = enabled
    if enabled then
        for _, player in pairs(Players:GetPlayers()) do CreateESP(player) end
    else
        for player, _ in pairs(ESPObjects) do RemoveESP(player) end
    end
end

Players.PlayerAdded:Connect(function(p) if ESPEnabled then CreateESP(p) end end)
Players.PlayerRemoving:Connect(RemoveESP)

