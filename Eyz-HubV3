                end)
            end
        end
        DropdownList.Size = UDim2.new(1, 0, 0, math.min(playerCount * 30, 150))
    end
    
    DropdownButton.MouseButton1Click:Connect(function()
        PlayerDropdownOpen = not PlayerDropdownOpen
        DropdownList.Visible = PlayerDropdownOpen
        if PlayerDropdownOpen then
            RefreshPlayerList()
            Container.Size = UDim2.new(1, -10, 0, 38 + DropdownList.Size.Y.Offset + 5)
        else
            Container.Size = UDim2.new(1, -10, 0, 38)
        end
    end)
    
    return Container, function() return SelectedPlayer end
end

