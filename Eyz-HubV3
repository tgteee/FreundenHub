-- ═══════════════════════════════════════════════════════════════

local Dragging = false
local DragInput = nil
local DragStart = nil
local StartPos = nil

local function UpdateDrag(input)
    local delta = input.Position - DragStart
    local targetPos = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + delta.X, StartPos.Y.Scale, StartPos.Y.Offset + delta.Y)
    
    -- Smooth tween drag
    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.08, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = targetPos})
    tween:Play()
end

